{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/aitask/schemas/waiver.schema.json",
  "title": "Waiver Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["waiver_id", "waived_control", "justification", "risk_accepted", "expiry", "approver", "compensating_controls", "linked_records"],
  "properties": {
    "waiver_id": {
      "type": "string",
      "pattern": "^WAIVER-\\d{4}-\\d{4}$"
    },
    "waived_control": {
      "type": "string"
    },
    "justification": {
      "type": "string"
    },
    "risk_accepted": {
      "type": "string"
    },
    "expiry": {
      "type": "string",
      "format": "date"
    },
    "approver": {
      "type": "string",
      "pattern": "^(human|agent|svc):[A-Za-z0-9._-]+$"
    },
    "compensating_controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "linked_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}